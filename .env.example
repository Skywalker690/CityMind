# OpenAI (server-only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Mapbox
# Use a public token (starts with pk.) for browser map rendering. The server can
# reuse it for temporary destination geocoding, or use a separate token below.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
MAPBOX_ACCESS_TOKEN=

# Routing
OSRM_BASE_URL=https://router.project-osrm.org
