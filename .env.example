# OpenAI (server-only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Maps Platform
# Restrict this browser-visible key by HTTP referrer and enable Maps JavaScript
# API. It powers the interactive route map and its Google Maps controls.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Google Cloud map ID for Advanced Markers or cloud map styling.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Restrict this server-only key by server IP and enable Routes API plus Places
# API (New). It resolves destinations and requests walking routes.
GOOGLE_MAPS_SERVER_API_KEY=

# Optional secondary routing provider. Set this only to an endpoint configured
# with a verified walking/foot profile; generic public demo endpoints do not
# guarantee walking routes.
OSRM_BASE_URL=
